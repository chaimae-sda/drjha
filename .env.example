# Mistral API key — used for OCR (image/PDF text extraction via Pixtral)
# Get yours at: https://console.mistral.ai/
VITE_MISTRAL_API_KEY=your_mistral_api_key_here

# HuggingFace API key — used for Darija translation (atlasia/Terjman-Ultra-v2.0)
# Get yours at: https://huggingface.co/settings/tokens
# NOTE: Terjman-Ultra-v2.0 is a gated model — you must also request access at:
# https://huggingface.co/atlasia/Terjman-Ultra-v2.0
VITE_HF_API_KEY=your_huggingface_api_key_here
