# Mistral API key — used for OCR (image/PDF text extraction via Pixtral)
# Get yours at: https://console.mistral.ai/
VITE_MISTRAL_API_KEY=your_mistral_api_key_here

# Google Gemini API key — used for Darija translation
# Get yours (free) at: https://aistudio.google.com/app/apikey
VITE_GOOGLE_API_KEY=your_google_api_key_here
